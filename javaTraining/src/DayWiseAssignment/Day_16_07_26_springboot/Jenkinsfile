pipeline {
    agent any

    environment {
        DOCKERHUB_CREDENTIALS = credentials('dockerhub-creds')
        DOCKERHUB_USER        = 'hiteshpatwal'
        IMAGE_NAME            = 'spring-boot-bookapp'
        IMAGE_TAG             = "${env.BUILD_NUMBER}"
        KUBECONFIG            = 'C:\\Users\\hites\\.kube\\config'
        PROJECT_DIR           = 'javaTraining\\src\\DayWiseAssignment\\Day_16_07_26_springboot'
    }

    stages {

        stage('Checkout') {
            steps {
                git branch: 'main',
                    url: 'https://github.com/Hitesh11112/javaTraining.git'
            }
        }

        stage('Build') {
            steps {
                dir("${PROJECT_DIR}") {
                    bat 'mvnw.cmd clean package -DskipTests'
                }
            }
        }

        stage('Docker Build') {
            steps {
                dir("${PROJECT_DIR}") {
                    bat "docker build -t %DOCKERHUB_USER%/%IMAGE_NAME%:%IMAGE_TAG% ."
                }
            }
        }

        stage('Docker Push') {
            steps {
                bat "echo %DOCKERHUB_CREDENTIALS_PSW%| docker login -u %DOCKERHUB_CREDENTIALS_USR% --password-stdin"
                bat "docker push %DOCKERHUB_USER%/%IMAGE_NAME%:%IMAGE_TAG%"
            }
        }

        stage('Deploy to Minikube') {
            steps {
                dir("${PROJECT_DIR}") {
                    bat "kubectl apply -f k8s/book.yml"
                }
            }
        }

        stage('Verify Rollout') {
            steps {
                bat "kubectl rollout status deployment/book-deployment --timeout=90s"
            }
        }
    }

    post {
        success {
            echo "Build #${IMAGE_TAG} deployed to Minikube successfully"
        }
        failure {
            echo "Pipeline failed — check console output above"
        }
        always {
            bat 'docker logout'
        }
    }
}